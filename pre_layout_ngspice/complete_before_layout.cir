.include TSMC_180nm.txt
.param SUPPLY=1.8
.param VGG=1.8
.param LAMBDA=0.09u
.param width_N={20*LAMBDA}
.param width_P={2*width_N}
.global gnd vdd
.param VDD=1.8V


VSRC f gnd 1.8V
VS   clk  0 PULSE(0 {VDD} 5n 1p 1p 10n 20n) 
VSb   clkb  0 PULSE({VDD} 0 5n 1p 1p 10n 20n)    
Va1   a1i   gnd PULSE(0 1.8 0n 1p 1p 20n 40n)
Va2   a2i   gnd PULSE(0 1.8 0n 1p 1p 40n 80n)
Va3   a3i   gnd PULSE(0 1.8 0n 1p 1p 80n 160n)
Va4   a4i   gnd PULSE(0 1.8 0n 1p 1p 160n 320n)
Va5   a5i   gnd PULSE(0 1.8 0n 1p 1p 320n 640n)

Vb1   b1i   gnd 1.8V
Vb2   b2i   gnd 0V
Vb3   b3i  gnd 0V
Vb4   b4i   gnd 0V
Vb5   b5i   gnd 0V


C1 p1o gnd 10f
C0 g1 gnd 10f
C2 c6 gnd 10f
C3 s2o gnd 10f
C4 s3o gnd 10f
C5 s4o gnd 10f
C6 s5o gnd 10f







M_a1_1 a1i clkb ka1 gnd CMOSN W={width_N} L={2*LAMBDA}
+ AS={5*width_N*LAMBDA} PS={10*LAMBDA+2*width_N} AD={5*width_N*LAMBDA} PD={10*LAMBDA+2*width_N}

M_a1_2 a1i clk ka1 f CMOSP W={width_P} L={2*LAMBDA}
+ AS={5*width_P*LAMBDA} PS={10*LAMBDA+2*width_P} AD={5*width_P*LAMBDA} PD={10*LAMBDA+2*width_P}

M_a1_3 ua1 clk la1 gnd CMOSN W={width_N} L={2*LAMBDA}
+ AS={5*width_N*LAMBDA} PS={10*LAMBDA+2*width_N} AD={5*width_N*LAMBDA} PD={10*LAMBDA+2*width_N}

