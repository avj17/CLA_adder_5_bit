.include TSMC_180nm.txt
.param SUPPLY=1.8
.param VGG=1.8
.param LAMBDA=0.09u
.param width_N={20*LAMBDA}
.param width_P={2*width_N}
.global gnd vdd
.param VDD=1.8V


VSRC f gnd 1.8V
Va1   a1   gnd 1.8V
Va1b  a1b  gnd 0V
Va2   a2   gnd 1.8V
Va2b  a2b  gnd 0V
Va3   a3   gnd 1.8V
Va3b  a3b  gnd 0V
Va4   a4   gnd 1.8V
Va4b  a4b  gnd 0V
Va5   a5   gnd PULSE(0 1.8 0n 1p 1p 20n 40n)
Va5b  a5b  gnd PULSE(1.8 0 0n 1p 1p 20n 40n)
Vb1   b1   gnd PULSE(0 1.8 0n 1p 1p 10n 20n)
Vb1b  b1b  gnd PULSE(1.8 0 0n 1p 1p 10n 20n)
Vb2   b2   gnd 0V
Vb2b  b2b  gnd 1.8V
Vb3   b3   gnd 0V
Vb3b  b3b  gnd 1.8V
Vb4   b4   gnd 0V
Vb4b  b4b  gnd 1.8V
Vb5   b5   gnd 0V
Vb5b  b5b  gnd 1.8V


C1 p1o gnd 10f
C0 g1 gnd 10f
C2 c6 gnd 10f
C3 s2o gnd 10f
C4 s3o gnd 10f
C5 s4o gnd 10f
C6 s5o gnd 10f







