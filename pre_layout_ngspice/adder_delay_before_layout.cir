Ms5_4 s5 c5b ks52 f CMOSP W={width_P} L={2*LAMBDA}
+ AS={5*width_P*LAMBDA} PS={10*LAMBDA+2*width_P} AD={5*width_P*LAMBDA} PD={10*LAMBDA+2*width_P}


Ms5_5 s5 p5b ks53 gnd CMOSN W={width_N} L={2*LAMBDA}
+ AS={5*width_N*LAMBDA} PS={10*LAMBDA+2*width_N} AD={5*width_N*LAMBDA} PD={10*LAMBDA+2*width_N}

Ms5_6 s5 p5 ks54 gnd CMOSN W={width_N} L={2*LAMBDA}
+ AS={5*width_N*LAMBDA} PS={10*LAMBDA+2*width_N} AD={5*width_N*LAMBDA} PD={10*LAMBDA+2*width_N}

Ms5_7 ks53 c5b gnd gnd CMOSN W={width_N} L={2*LAMBDA}
+ AS={5*width_N*LAMBDA} PS={10*LAMBDA+2*width_N} AD={5*width_N*LAMBDA} PD={10*LAMBDA+2*width_N}

Ms5_8 ks54 c5 gnd gnd CMOSN W={width_N} L={2*LAMBDA}
+ AS={5*width_N*LAMBDA} PS={10*LAMBDA+2*width_N} AD={5*width_N*LAMBDA} PD={10*LAMBDA+2*width_N}





.param VIM={0.5*VDD}
.meas tran t_a_rise  WHEN v(b1)=VIM  RISE=1
.meas tran t_c_rise  WHEN v(c6)=VIM  RISE=1
.meas tran t_ac_rise PARAM='t_c_rise - t_a_rise'

.meas tran t_a_fall  WHEN v(b1)=VIM  FALL=1
.meas tran t_c_fall  WHEN v(c6)=VIM  FALL=1
.meas tran t_ac_fall PARAM='t_c_fall - t_a_fall'  

.meas tran t_ac_worst PARAM='max(abs(t_ac_rise), abs(t_ac_fall))'

.ic v(c6) = 0V
.ic v(g1) = 1.8V
.ic v(p1) = 0V
.tran 10p 40ns

.control
run
set color0 = black
set color1 = white
set hcopypscolor = 1
set xbrushwidth = 4

plot v(c6) v(b1)-2 title "Arun_Venkat_2024102067_ADDER"
set curplottitle = "Arun_Venkat_2024102067_ADDER"
hardcopy Arun_Venkat_2024102067_Q3_Transient.eps v(p1) v(p2) v(p3) v(p4) v(p5)
.endc